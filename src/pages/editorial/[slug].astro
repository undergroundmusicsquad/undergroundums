---
import Seo from '../../components/Seo.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('editorial', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('editorial', ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const genres = [
  ...new Set(
    sortedPosts.flatMap((post) => post.data.genres ?? [])
  ),
].sort((a, b) => a.localeCompare(b));

const slugify = (value) =>
  value
    .toLowerCase()
    .trim()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

const categoryLabels = {
  'track-of-the-day': 'Track of the Day',
  'track-of-the-week': 'Track of the Week',
  'track-of-the-month': 'Track of the Month',
  interview: 'Interview',
  review: 'Review',
  'featured-album': 'Featured Album',
};


const seoTitle = `${post.data.title} | Underground Music Squad`;
const seoDescription = post.data.description;
const seoPath = `/editorial/${post.id}`;
const primaryGenre = post.data.genres?.[0];
const primaryGenrePath = primaryGenre ? `/editorial/genre/${slugify(primaryGenre)}` : undefined;
const seoKeywords = [...(post.data.genres ?? []), categoryLabels[post.data.category], 'underground music', 'music editorial'];
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  image: post.data.image,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'Underground Music Squad',
    url: 'https://undergroundmusic.party',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Underground Music Squad',
  },
  mainEntityOfPage: `https://undergroundmusic.party${seoPath}`,
  articleSection: categoryLabels[post.data.category],
  keywords: post.data.genres ?? [],
};

const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'Home',
    item: 'https://undergroundmusic.party/',
  },
  {
    '@type': 'ListItem',
    position: 2,
    name: 'Editorial',
    item: 'https://undergroundmusic.party/editorial',
  },
];

if (primaryGenre && primaryGenrePath) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 3,
    name: primaryGenre,
    item: `https://undergroundmusic.party${primaryGenrePath}`,
  });
}

breadcrumbItems.push({
  '@type': 'ListItem',
  position: primaryGenre ? 4 : 3,
  name: post.data.title,
  item: `https://undergroundmusic.party${seoPath}`,
});

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
};

const formatDate = (date) =>
  date.toLocaleDateString('en-US', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });

const articleLinks = [
  {
    label: 'SoundCloud',
    href: post.data.links.soundcloud,
  },
  {
    label: 'Bandcamp',
    href: post.data.links.bandcamp,
  },
  {
    label: 'Spotify',
    href: post.data.links.spotify,
  },
  {
    label: 'YouTube',
    href: post.data.links.youtube,
  },
  {
    label: 'Instagram',
    href: post.data.links.instagram,
  },
  {
    label: 'Linktree',
    href: post.data.links.linktree,
  },
  {
    label: 'Website',
    href: post.data.links.website,
  },
]
  .map(({ label, href }) => ({
    label,
    href: href?.trim() ?? '',
  }))
  .filter(({ href }) => href.length > 0);
---

<!DOCTYPE HTML>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta name="color-scheme" content="light only" />
		<Seo title={seoTitle} description={seoDescription} path={seoPath} image={post.data.image} type="article" keywords={seoKeywords} publishedTime={post.data.date} modifiedTime={post.data.date} jsonLd={[articleJsonLd, breadcrumbJsonLd]} />
		<link href="https://fonts.googleapis.com/css2?display=swap&family=Instrument+Sans:ital,wght@0,400;0,500;0,700;1,400;1,500;1,700&family=Inter:ital,wght@0,400;1,400" rel="stylesheet" type="text/css" />
		<link rel="stylesheet" href="/assets/editorial/main.css" />
		<noscript><link rel="stylesheet" href="/assets/editorial/noscript.css" /></noscript>
		<style is:global>
			.ums-article-content .youtube-embed {
				display: block;
				position: relative;
				width: 100%;
				max-width: 100%;
				aspect-ratio: 16 / 9;
				margin: 1rem 0;
				overflow: hidden;
			}

			.ums-article-content .youtube-embed iframe {
				display: block;
				width: 100%;
				height: 100%;
				border: 0;
			}
		</style>
	</head>
	<body>
		<div class="site-wrapper">
			<div class="site-main" role="main">
				<div class="inner">
					<hr id="divider07" class="divider-component instance-7 style-7">
					<div id="container01" class="container-component instance-1 style-1 columns">
						<div class="wrapper">
							<div class="inner" data-onvisible-trigger="1">
								<div>
									<h1 id="text40" class="text-component instance-40 style-14">UNDERGROUND</h1>
									<h2 id="text02" class="text-component instance-2 style-18">MUSIC</h2>
									<h1 id="text03" class="text-component instance-3 style-16">SQUAD</h1>
								</div>
								<div>
									<h1 id="text41" class="text-component instance-41 style-19">SINCE 2020</h1>
									<h1 id="text42" class="text-component instance-42 style-20">SINCE 2020</h1>
									<h1 id="text43" class="text-component instance-43 style-21">SINCE 2020</h1>
									<h1 id="text08" class="text-component instance-8 style-22">SINCE 2020</h1>
								</div>
							</div>
						</div>
					</div>

					<ul id="buttons02" class="buttons-component instance-2 style-3">
						<li>
							<a href="/editorial" class="n01" role="button">EDITORIAL</a>
						</li>
					</ul>

					<div id="container02" class="container-component instance-2 style-3 columns">
						<div class="wrapper">
							<div class="inner" data-onvisible-trigger="1">
								<div>
									{genres.map((genre) => (
										<h1 class="text-component style-26">
											<a
												href={`/editorial/genre/${slugify(genre)}`}
												class="genre-link"
											>
												{genre}
											</a>
										</h1>
									))}
								</div>

								<div>
									{post.data.topLabel && (
										<p id="text82" class="text-component instance-82 style-23">
											{post.data.topLabel}
										</p>
									)}

									<p id="text38" class="text-component instance-38 style-9">
										{formatDate(post.data.date)}
									</p>

									<h1 id="text39" class="text-component instance-39 style-25">
										{post.data.title}
									</h1>

									<p id="text44" class="text-component instance-44 style-4">
										{post.data.description}
									</p>

									{post.data.image && (
										<div id="image07" class="image-component instance-7 style-1">
											<span class="frame">
												<img src={post.data.image} alt={post.data.title} />
											</span>
										</div>
									)}

									{post.data.music?.embed && (
										<div id="audio02" class="audio-component instance-2">
											<div class="frame">
												<iframe src={post.data.music.embed}></iframe>
											</div>
										</div>
									)}



									<p id="text47" class="text-component instance-47 style-9">
										{categoryLabels[post.data.category]}
									</p>

									<p id="text45" class="text-component instance-45 style-6">
										<span class="p">
											<em>
												{post.data.genres.map((genre) => (
													<>
														{genre}<br />
													</>
												))}
											</em>
										</span>
									</p>

									<div class="ums-article-content text-component instance-44 style-4">
										<Content />
									</div>
{articleLinks.length > 0 && (
  <ul
    id="article-links"
    class="links-component instance-8 article-links-column"
  >
    {articleLinks.map((link) => (
      <li>
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
)}
									

									{post.data.bottomLabel && (
										<p id="text75" class="text-component instance-75 style-23">
											{post.data.bottomLabel}
										</p>
									)}

									<ul id="links08" class="links-component instance-8">
										<li class="n01">
											<a href="/editorial">← Back to Editorial</a>
										</li>
									</ul>
                  <ul id="links08" class="links-component instance-8">
										<li class="n01">
											<a href="/">← Home</a>
										</li>
									</ul>
									
								</div>
							</div>
						</div>
					</div>

					<div id="container03" class="container-component instance-3 style-1 columns">
						<div class="wrapper">
							<div class="inner" data-onvisible-trigger="1">
								<div>
									<hr id="divider04" class="divider-component instance-4 style-13">

                  
									<ul id="links09" class="links-component instance-9">
										<li class="n01">
											<a href="https://www.instagram.com/undergroundmusicsquad" target="_blank">Instagram →</a>
										</li>
									</ul>
									<ul id="links10" class="links-component instance-10">
										<li class="n01">
											<a href="https://open.spotify.com/user/0plns05vdbfkzf07f0i6rs4b0" target="_blank">Spotify →</a>
										</li>
									</ul>
									<ul id="links11" class="links-component instance-11">
										<li class="n01">
											<a href="https://www.youtube.com/@undergroundmusics" target="_blank">youtube →</a>
										</li>
									</ul>
									<ul id="links12" class="links-component instance-12">
										<li class="n01">
											<a href="https://soundcloud.com/undergroundmusicsquad" target="_blank">soundcloud →</a>
										</li>
									</ul>
									<ul id="links07" class="links-component instance-7">
										<li class="n01">
											<a href="https://sbmt.to/um-squad" target="_blank">SUBMIT MUSIC →</a>
										</li>
									</ul>
								</div>
								<div>
									<div id="table02" class="table-component instance-2 style-1">
										<div class="inner">
											<table>
												<tbody>
												<script async src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="83d0eedf-9fec-4d2a-af0d-444bc9246a94"></script>	
												</tbody>
											</table>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>

				</div>
			</div>
		</div>
		<script is:inline src="/assets/editorial/main.js"></script>
	</body>
</html>

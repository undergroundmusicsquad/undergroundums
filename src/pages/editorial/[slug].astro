---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('editorial');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const siteGenres = [
  'Progressive Rock',
  'Surf Rock',
  'Psychedelic Rock',
  'Shoegaze',
  'Postpunk',
  'Synthpop',
  'Darkwave',
  'Dream Pop',
  'Experimental',
  'Noise',
  'Garage Rock',
  'Coldwave',
];

const categoryLabels = {
  'track-of-the-day': 'Track of the Day',
  'track-of-the-week': 'Track of the Week',
  'track-of-the-month': 'Track of the Month',
  interview: 'Interview',
  review: 'Review',
  'featured-album': 'Featured Album',
};

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});

const hasHeroMusic =
  post.data.music?.platform === 'bandcamp' &&
  post.data.music?.embed &&
  post.data.music?.placement === 'hero';
---

<BaseLayout
  title={`${post.data.title} | Underground Music Squad`}
  description={post.data.description}
  image={post.data.image}
  css="/assets/article/main.css"
  js="/assets/article/main.js"
  noscript="/assets/article/noscript.css"
>
  <div class="site-wrapper">
    <div class="site-main" role="main">
      <div class="inner">

        <hr id="divider07" class="divider-component instance-7 style-7">

        <div id="container01" class="container-component instance-1 style-1 columns">
          <div class="wrapper">
            <div class="inner" data-onvisible-trigger="1">
              <div>
                <h1 id="text40" class="text-component instance-40 style-14">UNDERGROUND</h1>
                <h2 id="text02" class="text-component instance-2 style-18">MUSIC</h2>
                <h1 id="text03" class="text-component instance-3 style-16">SQUAD</h1>
              </div>
              <div>
                <h1 id="text41" class="text-component instance-41 style-19">SINCE 2020</h1>
                <h1 id="text42" class="text-component instance-42 style-20">SINCE 2020</h1>
                <h1 id="text43" class="text-component instance-43 style-21">SINCE 2020</h1>
                <h1 id="text08" class="text-component instance-8 style-22">SINCE 2020</h1>
              </div>
            </div>
          </div>
        </div>

        <ul id="buttons02" class="buttons-component instance-2 style-3">
          <li>
            <a href="/editorial" class="n01" role="button">EDITORIAL</a>
          </li>
        </ul>

        <div id="container02" class="container-component instance-2 style-3 columns">
          <div class="wrapper">
            <div class="inner" data-onvisible-trigger="1">

              <div>
                {siteGenres.map((genre) => (
  <h1 class="text-component instance-94 style-26">{genre}</h1>
))}

                
              </div>

              <div>
{post.data.topLabel && (
  <p id="text11" class="text-component instance-11 style-23">
    {post.data.topLabel}
  </p>
)}


                <p id="text01" class="text-component instance-1 style-9">{formattedDate}</p>

                <h1 id="text39" class="text-component instance-39 style-25">
                  {post.data.title}
                </h1>

                <p id="text44" class="text-component instance-44 style-4">
                  {post.data.description}
                </p>

                {post.data.image && (
                  <div id="image07" class="image-component instance-7 style-1">
                    <span class="frame">
                      <img src={post.data.image} alt={post.data.title} />
                    </span>
                  </div>
                )}

                {hasHeroMusic && (
                  <div id="audio02" class="audio-component instance-2">
                    <div class="frame">
                      <iframe src={post.data.music.embed}></iframe>
                    </div>
                  </div>
                )}

                                <p id="text33" class="text-component instance-33 style-9">
                  {categoryLabels[post.data.category]}
                </p>

                <div class="ums-article-content">
                
                <p class="text-component instance-34 style-6">
  <span class="p">
    <em>
      {post.data.genres.map((genre) => (
        <>
          {genre}<br />
        </>
      ))}
    </em>
  </span>

</p>


  <Content />

</div>

  {post.data.bottomLabel && (
  <p class="text-component instance-82 style-23">
    {post.data.bottomLabel}
  </p>
)}

<ul id="links06" class="links-component instance-5">
  <li class="n01">
    <a href="/editorial">← Back to Editorial</a>
  </li>
</ul>

<ul id="links06" class="links-component instance-5">
  <li class="n01">
    <a href="/editorial">← Home</a>
  </li>
</ul>

<ul id="links12" class="links-component instance-1">
  <li><a href="https://www.instagram.com/undergroundmusicsquad" target="_blank">Instagram</a></li>
</ul>

<ul id="links11" class="links-component instance-1">
  <li><a href="https://open.spotify.com/user/0plns05vdbfkzf07f0i6rs4b0" target="_blank">Spotify</a></li>
</ul>



<ul id="links13" class="links-component instance-1">
  <li><a href="https://www.youtube.com/@undergroundmusics" target="_blank">YouTube</a></li>
</ul>

<ul id="links14" class="links-component instance-1">
  <li><a href="https://soundcloud.com/undergroundmusicsquad" target="_blank">SoundCloud</a></li>
</ul>

<ul id="links15" class="links-component instance-1">
  <li><a href="https://sbmt.to/um-squad" target="_blank">Submit Music →</a></li>
</ul>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>